		<style type="text/css" id="wp-custom-css">
			body.home .wpcp-post-title  {
	padding-top: 0;
}

.author > .mec-sl-location-pin {
	display: none;
}

.download-pdf > a {
	color: #fff;
}

#post-6 h2 {
	padding-top: 26px;
}

