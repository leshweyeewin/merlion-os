		<style>:root,::before,::after{--mec-heading-font-family: 'Roboto';--mec-paragraph-font-family: 'Roboto';--mec-color-skin: #114575;--mec-color-skin-rgba-1: rgba(17,69,117,.25);--mec-color-skin-rgba-2: rgba(17,69,117,.5);--mec-color-skin-rgba-3: rgba(17,69,117,.75);--mec-color-skin-rgba-4: rgba(17,69,117,.11);--mec-primary-border-radius: ;--mec-secondary-border-radius: ;--mec-container-normal-width: 1196px;--mec-container-large-width: 1690px;--mec-fes-main-color: #40d9f1;--mec-fes-main-color-rgba-1: rgba(64, 217, 241, 0.12);--mec-fes-main-color-rgba-2: rgba(64, 217, 241, 0.23);--mec-fes-main-color-rgba-3: rgba(64, 217, 241, 0.03);--mec-fes-main-color-rgba-4: rgba(64, 217, 241, 0.3);--mec-fes-main-color-rgba-5: rgb(64 217 241 / 7%);--mec-fes-main-color-rgba-6: rgba(64, 217, 241, 0.2);</style><style>#mec_skin_11733 h2 {
  display: inline !important;
}

.mec-wrap li.mec-event-social-icon a>svg {
    width: 26px !important;
    height: 27px !important;
    padding: 4px;
}

.mec-event-list-modern .mec-event-sharing > .mec-event-social-icon .mec-social-title {
  display: none;
}

.mec-event-list-modern .mec-event-sharing > .mec-event-social-icon i {
  width: 26px;
  line-height: 25px;
}

.mec-event-list-modern .mec-event-sharing > .mec-event-social-icon:first-child {
   margin-left: 0;
}

.mec-event-list-modern ul.mec-event-sharing {
   flex-wrap: nowrap;
}
.mec-calendar .mec-calendar-events-side h3.mec-table-side-day {
    font-size: 12px;
    display: inline-block;
}

.mec-event-list-modern .mec-event-date .event-da {
    font-size: 27px;
}
.mec-wrap p {
    color: #000000;
    font-weight: 400 !important;
}
.mec-single-event-description.mec-events-content {
    color: #000000;
}
.mec-wrap .mec-single-title {
    color: #2C4674;
}
.mec-event-list-modern .mec-btn-wrapper .mec-booking-button {
    background-color: #2C4674;
    color: white;
}
.mec-wrap .mec-event-list-modern .mec-event-title a:visited,
.mec-wrap .mec-event-list-modern .mec-event-title a:link,
.mec-wrap .mec-event-list-modern .mec-event-title a:hover {
    margin-top: 0;
    margin-bottom: 10px;
    font-family: Roboto, "Open Sans";
    color: #2C4674;
    font-weight: 600;
}

.event-color {
   display: none;
}
.mec-events-event-image {
    display: none !important;
}
.mec-calendar.mec-calendar-weekly .mec-event-list-weekly-date {
    width: 70px; //fit november text
}

@media only screen and (min-width: 767px) {
    .mec-wrap .row.mec-single-event {
        margin-left: 55px;
        margin-right: 57px;
    }
    .mec-wrap .col-md-9 {
        width: 75%;
        padding: 0px;
    }
    .mec-bg-color, .mec-bg-color-hover:hover, .mec-wrap .mec-bg-color, .mec-wrap .mec-bg-color-hover:hover {
        background-color: #114575;
    }
    .mec-event-list-minimal .mec-event-title {
        margin-top: 0;
        margin-bottom: 10px;
        font-weight: 700;
        font-size: 18px;
        text-transform: uppercase;
        letter-spacing: 0;
        padding-top: 0px;
    }
    .mec-wrap .mec-event-article .mec-color-hover {
        box-shadow: none;
        border: none;
        font-size: 13px;
    }
    .mec-event-list-minimal .mec-event-detail, .mec-event-list-minimal .mec-time-details {
        font-size: 12px;
        font-weight: 300;
        line-height: 1;
        letter-spacing: 0;
        color: #9a9a9a;
        font-family: Roboto,sans-serif;
    }
    .mec-event-list-minimal .mec-event-date {
        position: relative;
        float: left;
        margin-right: 10px;
        color: #fff;
        width: 52px;
        padding: 6px 4px 3px;
        text-align: center;
        text-transform: uppercase;
        border-radius: 3px;
    }
    .mec-event-list-minimal .mec-event-article {
        border-bottom: 1px solid #efefef;
        padding: 8px 0 8px;
    }
}

/* front page calendar */
.home.mec-theme-iseas .mec-event-list-minimal .mec-event-date {
  width: 52px;
}
.home.mec-theme-iseas .mec-event-list-minimal .mec-event-article {
  display: block;
}

.home.mec-theme-iseas .mec-event-list-minimal .mec-event-date {
  margin-right: 10px;
}

.home.mec-theme-iseas .mec-event-list-minimal .mec-event-article {
  padding: 8px 0;
}

.home.mec-theme-iseas .mec-event-list-minimal .mec-event-title {
  padding-top: 0;
  margin-bottom: 5px;
}

.home.mec-theme-iseas .event-color {
  display: none;
}

@media only screen and (max-width: 479px) {
    #page .mec-event-list-minimal .mec-event-date {
        float:left;
    }
    #page .mec-event-list-minimal .mec-event-date span {
	    display: block;
	    padding-right: 0;
	    margin-right: 0;
	    font-size: 24px;
	}
	#page .mec-event-list-minimal .mec-event-date:after {
	    width: 100%;
	}
	#page .mec-event-list-minimal .mec-event-title {
	    padding-top: 10px;
	    margin-bottom: 5px;
	}
	
	#page .mec-event-list-minimal .mec-event-title a {
	    font-size: 13px;
	}
	
	#page .mec-event-list-minimal {
		text-align: left;
	}
}

/**ME Calendar bullet points**/
.mec-event-content ul{
	margin-left:15px;
	font-family:'Roboto',sans-serif;
	font-weight:300;
}

#researcherData h2.entry-title{
	display: none !important;	
}

@media only screen and (max-width: 959px){
	.site-header {
			height: auto;

	}
}

html {
  scroll-behavior: smooth;
}

h2{
	padding-top:62px;
	display:flex !important;
}

.stickyontop{
	position:sticky;
	    top: 0;
/*     padding: 32px 0 10px; */
	padding: 10px 0 10px;
	background-color:#ffffff;
}

.stickyontop .wp-block-group__inner-container{
	overflow: hidden; 
	height: 40px;
}

.stickyontop .right-arrow{
	position: absolute;
	right: -20px;
	top: 25px;
}

.stickyontop .right-arrow span{
	display: block;
	width: 0;
	height: 0;
	border-top: 5px solid transparent;
	border-left: 10px solid #114575;
	border-bottom: 5px solid transparent;
}

.stickyontop .left-arrow{
	position: absolute;
	left: -20px;
	top: 25px;
}

.stickyontop .left-arrow span{
	display: block;
	width: 0;
	height: 0;
	border-top: 5px solid transparent;
	border-right: 10px solid #114575;
	border-bottom: 5px solid transparent;
	visibility: hidden;
}

@media (max-width: 767.98px) {
  .stickyontop .left-arrow,
	.stickyontop .right-arrow{
		display: none;
	}
}

.stickyontop ul{
	display:flex;
/* 	flex-wrap:nowrap; */
	list-style-type:none;
/* 	overflow-x:none; */
	
white-space: nowrap;
  position: relative;
  overflow-x: scroll;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;

}

.stickyontop ul > * {
    -webkit-transform: translateZ(0px);
}

.stickyontop ul li{
	margin: 8px 16px 8px 0px;
}

.stickyontop ul li a{
	text-decoration: none;
	font-size: 12px;
	text-transform: uppercase;
	margin: 0px;
	padding: 8px 18px;
/* 	background-color: #919597; */
	background-color:#114575;
	color: #ffffff !important;
	
}

.stickyontop ul li a.active{
/* 	background-color:#114575; */
}

.stickyontop ul li a:hover,
.stickyontop ul li a:focus{
/* 	background-color:#114575; */
}


.download-pdf{
	display: flex;
	justify-content: center;
	margin-bottom: 20px;
}

.download-pdf.left{
	justify-content: flex-start;
}
.download-pdf a,
.download-pdf a:hover,
.download-pdf a:visited{
	text-decoration: none;
    font-size: 12px;
    text-transform: uppercase;
    margin: 0px;
    padding: 8px 18px;
    background-color: #114575;
    color: #ffffff;
}
/* Remove menu item source guide */
.item-hide{display:none;}

/* Library landing page serach */
.lib_search_more{display:none;}
.lib_search{margin-right:30px;width:100% !important;}
.searchline{display:flex;}
.searchline #qu{width:100% !important;}
.search-specific{
	width:100% !important;
	text-align:center;
	border-bottom-right-radius: 20px;
}
@media(max-width:960px){
.lib_search{width:85% !important;}
}

/* hide pagination articles commentaries */
.category-articles-commentaries.category-135 .pagination{
	display:none;
}

/* Sidebar menu dropdown */
.active-accordion{
	display:inline-block;
	transform:rotate(180deg);
}
#menu-menu-articles-comment .menu-item-has-children > a{
	width:93%;
	display: inline-block;
}
#menu-menu-articles-comment .toggle{
	cursor:pointer;
}
/* Seemore library blog */
.library-wrap header.title{
	justify-content:space-between;
}
.seemore{color:black;}
.library-wrap .title-3 a.seemore, .library-wrap .title-2 a.seemore{
	margin-top:40px;
}
.library-wrap .title-4 a.seemore{
	padding-top:60px;
}
.library-wrap a.seemore{
	font-size:19px;
}</style>
</head>

