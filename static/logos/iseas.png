<script type="text/javascript">
$(document).ready(function(){
	$('#up').on('click', function() {
		$('.entry-title').animate({
			'font-size': '+=1'
		});
		$('#entry-content').animate({
			'font-size': '+=1'
		});
		$('.entry-content').animate({
			'font-size': '+=1'
		});
		$('.itemTitle').animate({
			'font-size': '+=1'
		});
		$('.entry-content p').animate({
			'font-size': '+=1'
		});
		$('.entry-content h4').animate({
			'font-size': '+=1'
		});
		$('.entry-content figcaption').animate({
			'font-size': '+=1'
		});
	});

	$('#down').on('click', function() {
		$('.entry-title').animate({
			'font-size': '-=1'
		});
		$('#entry-content').animate({
			'font-size': '-=1'
		});
		$('.entry-content').animate({
			'font-size': '-=1'
		});
		$('.itemTitle').animate({
			'font-size': '-=1'
		});
		$('.entry-content p').animate({
			'font-size': '-=1'
		});
		$('.entry-content h4').animate({
			'font-size': '-=1'
		});
		$('.entry-content figcaption').animate({
			'font-size': '-=1'
		});

	});

  var scroll;
  $('.stickyontop ul').each(function() {
      let x, left;
      let scrollWidth = $(this)[0].scrollWidth;
      $(this).mousedown(function(e) {
        e.preventDefault();
          scroll = false;
          down = true;
          x = e.pageX;
          left = $(this).scrollLeft();
      });

      $(this).mousemove(function(e) {
        if (down) {
          let newX = e.pageX;
          $(this).scrollLeft(left - newX + x);
          
          if($(this).scrollLeft() > 0){
             $('.left-arrow span').css('visibility','visible');
          }else{
            $('.left-arrow span').css('visibility','hidden');
          }
          if($(this).scrollLeft() + $(this).width() < scrollWidth - 2 ){
           $('.right-arrow span').css('visibility','visible');
          }else{
            $('.right-arrow span').css('visibility','hidden');
          }

          if(Math.abs(newX - x) > 2){
            scroll = true;
          }
        }
      });

      $(this).mouseup(function(e) {
        down = false;
      });

      $(this).mouseleave(function(e) {
        $(this).trigger('mouseup');
      });

  });

  $('.stickyontop ul li a').on('click', function(e){
    console.log(scroll);
    if(scroll){
      scroll = false;
      return false;
    }else{
      $(this)[0].click()
    }
  })

  var scrollHandle = 0,
  scrollStep = 5,
  parent = $('.stickyontop ul');

  //Start the scrolling process
  $(".left-arrow").on("mousedown", function (e) {
    direction = -1;

    $(this).addClass('active');

    startScrolling(direction, scrollStep);
  });

  //Kill the scrolling
  $(".left-arrow").on("mouseup", function (e) {
    stopScrolling();
    $(this).removeClass('active');
  });

  //Start the scrolling process
  $(".right-arrow").on("mousedown", function (e) {
    direction = 1;

    $(this).addClass('active');

    startScrolling(direction, scrollStep);
  });

  //Kill the scrolling
  $(".right-arrow").on("mouseup", function (e) {
    stopScrolling();
    $(this).removeClass('active');
  });

  //Actual handling of the scrolling
  function startScrolling(modifier, step) {
    if (scrollHandle === 0) {
      scrollHandle = setInterval(function () {
        var newOffset = parent.scrollLeft() + (scrollStep * modifier);

        parent.scrollLeft(newOffset);

        if(parent.scrollLeft() > 0){
          $('.left-arrow span').css('visibility','visible');
        }else{
          $('.left-arrow span').css('visibility','hidden');
          $('.left-arrow').trigger('mouseup');
        }
        if(parent.scrollLeft() + parent.width() < parent[0].scrollWidth - 2 ){
          $('.right-arrow span').css('visibility','visible');
        }else{
          $('.right-arrow span').css('visibility','hidden');
          $('.right-arrow').trigger('mouseup');
        }
      }, 10);
    }
  }

  function stopScrolling() {
    clearInterval(scrollHandle);
    scrollHandle = 0;
  }
});
</script>

