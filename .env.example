# ─── MerlionOS Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Real environment variables always win — values in .env are only defaults.

# ── Required ──────────────────────────────────────────────────────────────────
# Get a free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Get from LTA DataMall: https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_DATAMALL_API_KEY="YOUR_LTA_DATAMALL_API_KEY"

# ── Optional: data.gov.sg ─────────────────────────────────────────────────────
# APIs work unauthenticated, but this key lifts the rate limit so NEA calls skip pacing.
DATA_GOV_SG_API_KEY="YOUR_DATA_GOV_SG_API_KEY"

# ── Optional: Google BigQuery (Job Market Dashboard) ─────────────────────────
# Without these the server falls back to live data.gov.sg fetches automatically.
# GCP_PROJECT_ID="your-gcp-project-id"
# GOOGLE_APPLICATION_CREDENTIALS="./service-account-key.json"

# ── Optional: Server ──────────────────────────────────────────────────────────
# Default is 8000. Set to 8080 for Cloud Run compatibility.
# PORT=8000
# RELOAD=false
